# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Somnia Testnet RPC (default is public endpoint)
SOMNIA_RPC=https://dream-rpc.somnia.network

# Block explorer API key for contract verification
SOMNIA_EXPLORER_API_KEY=your_api_key_here

# Enable gas reporting (true/false)
REPORT_GAS=false
